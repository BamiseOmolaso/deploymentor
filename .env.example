# DeployMentor Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# GitHub Token (for local development)
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# AWS Configuration (optional - for local AWS CLI)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1

# AWS Account ID (for reference - get from: aws sts get-caller-identity)
AWS_ACCOUNT_ID=your_account_id_here

# GitHub OIDC Role ARN (get from: terraform output github_actions_role_arn)
AWS_ROLE_ARN=arn:aws:iam::your_account_id:role/deploymentor-github-actions-role-dev

# API Gateway URL (get from: terraform output api_gateway_url)
API_GATEWAY_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/

# SSM Parameter Path (for GitHub token)
GITHUB_TOKEN_SSM_PARAM=/deploymentor/github/token

# GitHub Repository (for OIDC configuration)
GITHUB_REPO=your-username/deploymentor

# Test Workflow IDs (optional - for testing)
TEST_WORKFLOW_OWNER=your-username
TEST_WORKFLOW_REPO=your-repo
TEST_WORKFLOW_RUN_ID=123456789
